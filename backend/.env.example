# Copier vers backend/.env si besoin.

# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données : par défaut le projet utilise SQLite (backend/db.sqlite3).
# Ne pas définir DATABASE_URL pour rester en SQLite.
#
# Pour Postgres (ex. Supabase), décommenter et adapter :
# DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# CORS (optionnel)
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
