# Frontend (dossier frontend/) — copier ce fichier vers .env.local

# URL du backend Django (sans slash final).
# En local : http://127.0.0.1:8000 ou http://localhost:8000
#
# Sur Vercel (ou tout hébergeur public) : NE PAS utiliser 127.0.0.1 — le build embarque cette
# valeur et le navigateur bloque (Private Network Access / loopback). Mets l’URL HTTPS publique
# de ton API Django, ex. https://ton-service-api.up.railway.app
# Variable Vercel : VITE_API_URL
VITE_API_URL=http://127.0.0.1:8000

# Projet Supabase → Settings → API (URL + clé anon / publishable)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key

# Billetterie (boutons « S'inscrire » sur l'accueil, les pages ateliers et /inscription)
# URL HTTPS publique — sans ce champ, le bouton Émotions reste grisé (« billetterie à venir »).
VITE_BILLETTERIE_EMOTIONS_URL=
# Optionnel : quand la billetterie Impro sera prête
# VITE_BILLETTERIE_IMPRO_URL=
